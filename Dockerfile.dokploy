FROM node:22-alpine AS app

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

RUN corepack enable

WORKDIR /app

COPY web/package.json web/pnpm-lock.yaml web/pnpm-workspace.yaml ./web/

WORKDIR /app/web
RUN pnpm install --frozen-lockfile

WORKDIR /app
COPY data ./data
COPY GPT-ASSETS ./GPT-ASSETS
COPY web ./web

WORKDIR /app/web
RUN pnpm exec prisma generate
RUN pnpm build

EXPOSE 3000

CMD ["sh", "-c", "pnpm exec prisma migrate deploy && (pnpm db:seed || echo 'Seed failed; continuing startup') && pnpm start"]
