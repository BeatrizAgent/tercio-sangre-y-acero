generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  name            String
  tokenHash       String    @unique
  tokenIssuedAt   DateTime  @default(now())
  lastLoginAt     DateTime?
  isBot           Boolean   @default(false)
  /// Last public IP observed by the server during create/resume/recovery.
  /// Used only as a coarse recovery hint; tokens are still rotated and hashed.
  lastLoginIp     String?
  createdAt       DateTime  @default(now())
  /// Selected player portrait (id from data/player-portraits.json).
  /// Null for legacy users: the client falls back to the hardcoded
  /// "diego de arce" portrait.
  portraitAssetId String?
  soldier         Soldier?
  gameSave        GameSave?

  @@index([lastLoginIp, lastLoginAt])
}

model Soldier {
  id              String          @id @default(cuid())
  userId          String          @unique
  name            String
  rank            String
  coins           Int
  honor           Int
  xp              Int
  fatigue         Int
  unpaidWages     Int
  reputation      Int
  corruption      Int             @default(0)
  banMissionsLeft Int             @default(0)
  /// Mirrors User.portraitAssetId for fast reads; updated by
  /// persistGameStateForUser in web/src/lib/actions/_demo.ts.
  portraitAssetId String?
  saveState       Json?
  user            User            @relation(fields: [userId], references: [id])
  stats           SoldierStats?
  inventory       InventoryItem[]
  equipment       Equipment?
  wounds          ActiveWound[]
  results         MissionResult[]
  trainingLog     TrainingLog[]
  arenaBotProfile ArenaBotProfile?
  activeMission   ActiveMission?
}

model ArenaBotProfile {
  id               String   @id @default(cuid())
  soldierId        String   @unique
  style            String
  description      String
  active           Boolean  @default(true)
  seedOffset       Int
  lastProgressedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  soldier          Soldier  @relation(fields: [soldierId], references: [id])

  @@index([active, seedOffset])
}

model GameSave {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CharacterName {
  id         String   @id @default(cuid())
  kind       String
  value      String
  normalized String
  sortOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([kind, normalized])
  @@index([kind, sortOrder])
}

model SoldierStats {
  id         String  @id @default(cuid())
  soldierId  String  @unique
  pike       Int
  sword      Int
  arquebus   Int
  discipline Int
  vigor      Int
  cunning    Int
  command    Int
  soldier    Soldier @relation(fields: [soldierId], references: [id])
}

model ItemDefinition {
  id           String          @id
  name         String
  category     String
  slot         String
  footprint    Json
  value        Int
  effects      Json
  description  String
  rarity       String?
  tier         Int?
  passives     Json?
  requirements Json?
  assetId      String?
  inventory    InventoryItem[]
  shopItems    ShopItem[]
  shopRotations ShopRotation[]
  auctionListings AuctionListing[]
}

model InventoryItem {
  id        String         @id @default(cuid())
  soldierId String
  itemId    String
  quantity  Int
  soldier   Soldier        @relation(fields: [soldierId], references: [id])
  item      ItemDefinition @relation(fields: [itemId], references: [id])

  @@unique([soldierId, itemId])
}

model Equipment {
  id         String  @id @default(cuid())
  soldierId  String  @unique
  head       String?
  body       String?
  mainHand   String?
  offHand    String?
  firearm    String?
  accessory  String?
  boots      String?
  consumable String?
  soldier    Soldier @relation(fields: [soldierId], references: [id])
}

model MissionDefinition {
  id           String          @id
  title        String
  type         String
  difficulty   Int
  enemyId      String
  sceneAssetId String?
  rewards      Json
  fatigue      Int
  woundChance  Int
  woundId      String?
  lootTableId  String?
  reportTags   String[]
  x            Int
  y            Int
  locationType String
  region       String?
  results      MissionResult[]
  activeMissions ActiveMission[]
}

model MissionResult {
  id        String            @id @default(cuid())
  soldierId String
  missionId String
  success   Boolean
  report    String
  rewards   Json
  wounds    Json
  loot      Json
  createdAt DateTime          @default(now())
  soldier   Soldier           @relation(fields: [soldierId], references: [id])
  mission   MissionDefinition @relation(fields: [missionId], references: [id])
}

model ActiveMission {
  id          String    @id @default(cuid())
  soldierId   String    @unique
  missionId   String
  startedAt   DateTime  @default(now())
  completesAt DateTime
  claimedAt   DateTime?
  status      String    @default("active")
  resultId    String?
  soldier     Soldier   @relation(fields: [soldierId], references: [id])
  mission     MissionDefinition @relation(fields: [missionId], references: [id])

  @@index([status, completesAt])
}

model WoundDefinition {
  id             String        @id
  name           String
  severity       Int
  effects        Json
  description    String
  treatmentItems Json
  active         ActiveWound[]
}

model ActiveWound {
  id        String          @id @default(cuid())
  soldierId String
  woundId   String
  treated   Boolean         @default(false)
  soldier   Soldier         @relation(fields: [soldierId], references: [id])
  wound     WoundDefinition @relation(fields: [woundId], references: [id])
}

model ShopItem {
  id        String         @id @default(cuid())
  shopId    String         @default("company_armory")
  itemId    String
  buyPrice  Int
  sellPrice Int
  stock     Int
  item      ItemDefinition @relation(fields: [itemId], references: [id])

  @@unique([shopId, itemId])
}

model ShopRotation {
  id             String   @id @default(cuid())
  shopId         String
  itemId         String
  buyPrice       Int
  sellPrice      Int
  stock          Int
  maxStock       Int
  refreshedAt    DateTime @default(now())
  nextRefreshAt  DateTime
  item           ItemDefinition @relation(fields: [itemId], references: [id])

  @@unique([shopId, itemId])
  @@index([shopId, nextRefreshAt])
}

model AuctionListing {
  id              String       @id @default(cuid())
  sellerId        String
  itemId          String
  quantity        Int          @default(1)
  startingBid     Int
  currentBid      Int?
  currentBidderId String?
  buyoutPrice     Int?
  status          String       @default("active")
  endsAt          DateTime
  claimedAt       DateTime?
  sellerClaimedAt DateTime?
  winnerClaimedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  item            ItemDefinition @relation(fields: [itemId], references: [id])
  bids            AuctionBid[]

  @@index([status, endsAt])
  @@index([sellerId, status])
  @@index([currentBidderId, status])
}

model AuctionBid {
  id         String         @id @default(cuid())
  listingId  String
  bidderId   String
  amount     Int
  createdAt  DateTime       @default(now())
  listing    AuctionListing @relation(fields: [listingId], references: [id])

  @@index([listingId, amount])
  @@index([bidderId, createdAt])
}

model WorldJobRun {
  id         String   @id @default(cuid())
  job        String
  ranAt      DateTime @default(now())
  status     String
  details    Json?

  @@index([job, ranAt])
}

model TrainingLog {
  id        String   @id @default(cuid())
  soldierId String
  stat      String
  cost      Json
  createdAt DateTime @default(now())
  soldier   Soldier  @relation(fields: [soldierId], references: [id])
}

model LootTable {
  id    String @id
  drops Json
}

model ReportFragment {
  id   String   @id
  type String
  tags String[]
  text String
}

model AssetDefinition {
  id           String  @id
  category     String
  path         String
  source       String
  dimensions   Json
  transparent  Boolean
  usage        Json
  mature       Boolean
  presentation String
}

model EnemyDefinition {
  id              String  @id
  name            String
  power           Int
  description     String
  portraitAssetId String?
}

model RankDefinition {
  id       String @id
  name     String
  minXp    Int
  minHonor Int
}

model GameEventDefinition {
  id           String  @id
  title        String
  text         String
  assetId      String?
  mature       Boolean @default(false)
  presentation String?
  choices      Json
}

model CharacterDefinition {
  id              String  @id
  name            String
  role            String
  rank            String
  portraitAssetId String
  tercioAssetId   String?
  emotionAssetId  String?
  spriteSetId     String?
  formationSlot   String
  fatigue         Int
  stats           Json
  equipment       Json
}

model SpriteSetDefinition {
  id     String @id
  name   String
  frames Json
}

model RecruitmentCandidateDefinition {
  id        String @id
  hook      String
  cost      Json
  character Json
}

model TrainingDefinition {
  stat        String @id
  name        String
  cost        Json
  gain        Int
  fatigue     Int
  description String
}
