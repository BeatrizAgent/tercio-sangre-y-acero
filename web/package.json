{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-data.mjs && next dev",
    "build": "node scripts/sync-data.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/sync-data.mjs && tsx prisma/seed.ts",
    "auctions:seed": "tsx scripts/seed-system-auctions.ts",
    "auctions:plan": "tsx scripts/seed-system-auctions.ts --dry-run",
    "test": "tsx tests/run-all.mjs",
    "test:api": "node tests/run-api.mjs",
    "test:domain": "tsx tests/run-domain.mjs",
    "test:store": "tsx tests/run-store.mjs",
    "test:data": "tsx tests/run-data.mjs",
    "test:ux": "tsx tests/run-ux.mjs",
    "validate": "node tests/validate-web-mvp.mjs && node tests/validate-db-contract.mjs && node ../scripts/validate_data_references.mjs && pnpm test"
  },
  "prisma": {
    "seed": "node scripts/sync-data.mjs && tsx prisma/seed.ts"
  },
